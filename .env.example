# ── Пример переменных окружения ──────────────────────────────────────
# Скопируйте в .env и при необходимости поменяйте значения.
# Значения ниже подходят для локального запуска с infra/docker-compose.yml.

# PostgreSQL (локально через docker compose -f infra/docker-compose.yml up -d)
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=bankruptcy_academy
DATABASE_USER=pravo
DATABASE_PASSWORD=pravo
DATABASE_SCHEMA=pravo

# Backend API
API_PORT=3001

# Адрес API для фронтенда. В dev можно не задавать — vite проксирует /api на :3001.
# VITE_API_URL=/api

# Пароль входа в админ-панель (/admin)
ADMIN_PASSWORD=changeme

# Загрузка файлов (байты). 10 МБ по умолчанию.
MAX_FILE_SIZE=10485760

# Домен для SEO-пререндера (sitemap.xml, robots.txt, og:url, canonical).
# Используется при `npm run build`. По умолчанию — плейсхолдер.
# SITE_URL=https://your-domain.ru

# Почта для отправки книг/чек-листов (SMTP Mail.ru)
MAIL_USER=
MAIL_APP_PASS=

# Telegram Bot (t.me/NeuroPravo_Bot)
TELEGRAM_BOT_TOKEN=

# JWT секрет для системы пользователей (уроки/курсы)
JWT_SECRET=pravo-tech-hub-jwt-secret-2026

# Директория с видео-уроками (абсолютный путь к MP4 файлам)
VIDEO_DIR=/path/to/video/files
